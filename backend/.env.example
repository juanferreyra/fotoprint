# Puerto del servidor
PORT=3000

# Ruta del archivo SQLite (relativa a backend/)
DATABASE_FILE=./data/fotoprint.sqlite

# Secreto para firmar la cookie de sesion. Generar con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Clave de 32 bytes (64 hex chars) para cifrar tokens/credenciales de nube en la DB. Generar con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=

# URL base publica del backend (usada para armar el redirect_uri de OAuth)
# Ej: http://localhost:3000
BASE_URL=http://localhost:3000

# --- Dropbox OAuth App (https://www.dropbox.com/developers/apps) ---
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=
